apiVersion: v1
kind: Secret
metadata:
  name: task-manager-mongo-secret
type: Opaque
stringData:
  MONGO_URI: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
  MONGO_DB_USERNAME: replace-with-mongo-username
  MONGO_DB_PASSWORD: replace-with-strong-random-password
  JWT_SECRET: replace-with-64-plus-random-characters

# Instructions:
# 1. Copy this file:
#    cp k8s/secret-aks.yaml.example k8s/secret-aks.yaml
# 
# 2. Replace the placeholder values:
#    - MONGO_URI: Your MongoDB Atlas connection string
#    - JWT_SECRET: Generate with: openssl rand -hex 48
#
# 2.1 Optional for strict CORS in production:
#    - Set FRONTEND_URL or FRONTEND_URLS (comma-separated) in your backend deployment.
# 
# 3. Apply to your cluster:
#    kubectl apply -f k8s/secret-aks.yaml
# 
# Note: secret-aks.yaml is gitignored to protect your credentials
